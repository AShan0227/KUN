# KUN 环境变量示例
# 复制为 .env 并填入真实值。不要把 .env 提交到 git。

# ===== 部署模式 =====
KUN_ENV=dev                       # dev / staging / production
KUN_LOG_LEVEL=INFO
KUN_DEFAULT_TENANT_ID=u-sylvan    # ADR-007 单租户默认

# ===== Postgres =====
KUN_PG_DSN=postgresql+asyncpg://kun:kun@localhost:5432/kun
KUN_PG_POOL_SIZE=10

# ===== Redis =====
KUN_REDIS_URL=redis://localhost:6379/0

# ===== Qdrant =====
KUN_QDRANT_URL=http://localhost:6333
KUN_QDRANT_API_KEY=

# ===== NATS =====
KUN_NATS_URL=nats://localhost:4222

# ===== MinIO / S3 =====
KUN_S3_ENDPOINT=http://localhost:9000
KUN_S3_ACCESS_KEY=minio
KUN_S3_SECRET_KEY=minio123
KUN_S3_BUCKET=kun-artifacts
KUN_S3_REGION=us-east-1

# ===== LLM Providers =====
# ADR-002: 开发期主力 Opus 4.7 + 次力 Codex 5.3 + 便宜档 Haiku/Sonnet + Fallback MiniMax
# 走 ofox proxy 做统一入口
KUN_OFOX_PROXY_URL=https://api.ofox.ai
KUN_OFOX_API_KEY=

# Anthropic (可选直连)
ANTHROPIC_API_KEY=

# OpenAI (可选直连)
OPENAI_API_KEY=

# MiniMax (ADR-002 fallback)
MINIMAX_API_KEY=
MINIMAX_API_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=minimax-m2.7

# ===== OpenTelemetry =====
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=kun-api
OTEL_RESOURCE_ATTRIBUTES=service.name=kun-api,service.version=0.1.0

# ===== API =====
KUN_API_HOST=0.0.0.0
KUN_API_PORT=8000
KUN_API_CORS_ORIGINS=http://localhost:3000

# ===== Budgets (ADR default, 可通过 UI 修改) =====
KUN_BUDGET_DAILY_USD=10.0
KUN_BUDGET_MONTHLY_USD=200.0
