# KUN 环境变量示例
# 复制为 .env 并填入真实值。不要把 .env 提交到 git。

# ===== 部署模式 =====
KUN_ENV=dev                       # dev / staging / production
KUN_LOG_LEVEL=INFO
KUN_DEFAULT_TENANT_ID=u-sylvan    # dev/staging fallback；production 会强制要求显式 tenant

# ===== Postgres =====
# Host 端口和 docker-compose.dev.yml 映射一致 (避免和其他项目冲突)。
# 应用运行时用非 superuser 角色 kun_app，让 Postgres RLS 真正生效；
# alembic/outbox 等系统任务走 admin DSN，走 superuser 绕过 RLS。
KUN_PG_DSN=postgresql+asyncpg://kun_app:kun_app@localhost:55432/kun
KUN_PG_ADMIN_DSN=postgresql+asyncpg://kun:kun@localhost:55432/kun
KUN_PG_POOL_SIZE=10

# ===== Redis =====
KUN_REDIS_URL=redis://localhost:6379/0

# ===== Qdrant =====
KUN_QDRANT_URL=http://127.0.0.1:16333
KUN_QDRANT_API_KEY=
KUN_EMBEDDING_PROVIDER=local     # local / openai / voyage / qdrant_fastembed
KUN_EMBEDDING_MODEL=             # openai: text-embedding-3-small; voyage: voyage-3-large
KUN_EMBEDDING_TIMEOUT_SEC=6.0
KUN_VOYAGE_API_KEY=

# ===== NATS =====
KUN_NATS_URL=nats://localhost:4222

# ===== MinIO / S3 =====
KUN_S3_ENDPOINT=http://localhost:19000
KUN_S3_ACCESS_KEY=minio
KUN_S3_SECRET_KEY=minio123
KUN_S3_BUCKET=kun-artifacts
KUN_S3_REGION=us-east-1

# ===== LLM Providers =====
# ADR-002: 开发期主力 Opus 4.7 + 次力 Codex 5.3 + 便宜档 Haiku/Sonnet + Fallback MiniMax
# 走 ofox proxy 做统一入口
KUN_OFOX_PROXY_URL=https://api.ofox.ai
KUN_OFOX_API_KEY=

# Anthropic (可选直连)
ANTHROPIC_API_KEY=

# OpenAI (可选直连)
OPENAI_API_KEY=

# MiniMax (ADR-002 fallback)
MINIMAX_API_KEY=
MINIMAX_API_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=minimax-m2.7

# ===== CLI OAuth providers =====
# Claude Code CLI (top/strong/cheap): uses your Claude Pro/Max subscription.
# Codex MCP server  (coding):         uses your ChatGPT subscription.
# Real API model id for ChatGPT accounts is "gpt-5.3-codex-spark" (the UI's
# "gpt-5.5" is a display label; the exec-CLI path rejects it).
# KUN_DISABLE_CODEX_CLI=1      # kill codex (MCP + exec), fall through to OpenAI/MiniMax
# KUN_DISABLE_CLI_OAUTH=1      # kill all CLI OAuth (claude + codex)
KUN_CODEX_MCP_MODEL=gpt-5.3-codex-spark

# ===== Subscription quota (5h rolling window) =====
# Hard downgrade caps: "none" = never auto-downgrade (test mode default for
# top/strong/cheap — user is on a flat subscription, not cost-sensitive).
# KUN_QUOTA_TOP=none
# KUN_QUOTA_STRONG=none
# KUN_QUOTA_CHEAP=none
# KUN_QUOTA_FALLBACK=10000     # MiniMax is metered, keep a cap
# Soft warn thresholds — log once per 30min when usage crosses this in the 5h
# window. Heads-up before the Claude Pro rate limit bites. 0 = silent.
# KUN_QUOTA_WARN_TOP=30
# KUN_QUOTA_WARN_STRONG=150
# KUN_QUOTA_WARN_CHEAP=0

# ===== OpenTelemetry =====
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:14317
OTEL_SERVICE_NAME=kun-api
OTEL_RESOURCE_ATTRIBUTES=service.name=kun-api,service.version=0.1.0

# ===== API =====
KUN_API_HOST=0.0.0.0
KUN_API_PORT=8000
KUN_API_CORS_ORIGINS=http://localhost:3000

# ===== Budgets (ADR default, 可通过 UI 修改) =====
KUN_BUDGET_DAILY_USD=10.0
KUN_BUDGET_MONTHLY_USD=200.0
